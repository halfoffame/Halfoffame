<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>ASS APP GPS</title>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>

<style>
body { margin:0; font-family:Arial; }
header { background:#1e90ff; color:white; padding:10px; text-align:center; }
button { width:100%; padding:15px; font-size:16px; }
#map { height:85vh; }
</style>
</head>

<body>

<header>ASS APP GPS</header>

<button onclick="getLocation()">📍 Konumumu Göster</button>

<div id="map"></div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
let map = L.map('map').setView([39,35],6);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution:'© OpenStreetMap'
}).addTo(map);

let marker;

function getLocation() {

    navigator.geolocation.getCurrentPosition(pos => {

        let lat = pos.coords.latitude;
        let lon = pos.coords.longitude;

        if(marker) map.removeLayer(marker);

        marker = L.marker([lat,lon])
            .addTo(map)
            .bindPopup("📍 Sen buradasın")
            .openPopup();

        map.setView([lat,lon],16);

    }, () => {
        alert("Konum izni verilmedi!");
    });

}
</script>

</body>
</html>
