<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<title>ASS APP GPS</title>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>

<style>
body { margin:0; font-family:Arial; }
header { background:#1e90ff; color:white; padding:10px; text-align:center; font-size:20px; }
#panel { padding:10px; text-align:center; }
input { width:70%; padding:10px; }
button { padding:10px; }
#map { height:85vh; }
</style>
</head>

<body>

<header>ASS APP GPS</header>

<div id="panel">
    <input id="searchBox" placeholder="Yer adı yaz...">
    <button onclick="searchLocation()">ARA</button>
</div>

<div id="map"></div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
let map = L.map('map').setView([39.0, 35.0], 6);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap'
}).addTo(map);

let marker;

async function searchLocation() {
    let place = document.getElementById("searchBox").value;

    let res = await fetch(
        `https://nominatim.openstreetmap.org/search?format=json&q=${place}`
    );

    let data = await res.json();

    if (data.length > 0) {
        let lat = data[0].lat;
        let lon = data[0].lon;

        if (marker) map.removeLayer(marker);

        marker = L.marker([lat, lon]).addTo(map)
            .bindPopup(place)
            .openPopup();

        map.setView([lat, lon], 15);
    } else {
        alert("Konum bulunamadı!");
    }
}
</script>

</body>
</html>
